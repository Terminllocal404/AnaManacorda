# ----------------------------------------------------------------------------
# Loja Ana Manacorda - variaveis de ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# ----------------------------------------------------------------------------

# Aplicacao
APP_NAME="Ana Manacorda"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.anamanacorda.com.br
FRONTEND_URL=https://anamanacorda.com.br

# Banco de dados (MySQL 8+)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ana_manacorda
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Sessao
SESSION_NAME=ana_session
SESSION_LIFETIME=7200
SESSION_SECURE=true

# E-mail (SMTP). MAIL_DRIVER pode ser "smtp" (producao) ou "log" (grava .eml em storage/mail)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.seuprovedor.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=nao-responda@anamanacorda.com.br
MAIL_FROM_NAME="Ana Manacorda"

# Mercado Pago (https://www.mercadopago.com.br/developers -> Suas integracoes -> Credenciais)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_RUNTIME=SERVER
MP_PIX_EXPIRATION_MINUTES=30

# Entrega
ENTREGA_CIDADE="Juiz de Fora"
ENTREGA_ESTADO=MG

# Rate limiting (requisicoes por janela)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=60
